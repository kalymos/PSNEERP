{
    // 1. Force l'injection des variables d'environnement directement dans CMake Tools (Universel)
    "cmake.configureEnvironment": {
        "PICO_TOOLCHAIN_PATH": "${userHome}/.pico-sdk/toolchain/14_2_Rel1"
    },

    // 2. Configuration globale des outils
    "cmake.generator": "Ninja",
    "cmake.cmakePath": "cmake",
    "raspberry-pi-pico.useCmakeTools": true,
    "raspberry-pi-pico.cmakeAutoConfigure": true,
    "C_Cpp.debugShortcut": false,
    "raspberry-pi-pico.ninjaPath": "ninja",
    "cmake.options.statusBarVisibility": "visible",
    "cmake.showSystemKits": true,

    // 3. Configuration des terminaux
    "terminal.integrated.env.windows": {
        "PICO_SDK_PATH": "${userHome}/.pico-sdk/sdk/2.2.0",
        "PICO_TOOLCHAIN_PATH": "${userHome}/.pico-sdk/toolchain/14_2_Rel1",
        "Path": "${userHome}/.pico-sdk/toolchain/14_2_Rel1/bin;${userHome}/.pico-sdk/picotool/2.2.0-a4/picotool;${userHome}/.pico-sdk/ninja/v1.12.1;${env:Path}"
    },
    "terminal.integrated.env.osx": {
        "PICO_SDK_PATH": "${userHome}/.pico-sdk/sdk/2.2.0",
        "PICO_TOOLCHAIN_PATH": "${userHome}/.pico-sdk/toolchain/14_2_Rel1",
        "PATH": "/usr/local/bin:/usr/bin:${userHome}/.pico-sdk/toolchain/14_2_Rel1/bin:${userHome}/.pico-sdk/picotool/2.2.0-a4/picotool:${userHome}/.pico-sdk/ninja/v1.12.1:${env:PATH}"
    },
        "terminal.integrated.env.linux": {
        "PICO_SDK_PATH": "${userHome}/.pico-sdk/sdk/2.2.0",
        "PATH": "/usr/local/bin:/usr/bin:${userHome}/.pico-sdk/picotool/2.2.0-a4/picotool:${env:PATH}"
    }

}


